# Supabase — Project Settings → API (URL + anon public)
# En local: copia estas líneas a .env.local y pega tus valores reales.
VITE_SUPABASE_URL=https://TU_REF.supabase.co
VITE_SUPABASE_ANON_KEY=tu_clave_anon_publica

# Backend Spring Boot (ajusta puerto y prefijo a tu proyecto)
# Ej.: app en 8080 con controladores bajo /api →
VITE_API_URL=http://localhost:8080/api

# Opcional: forzar error en mocks del servicio admin (desarrollo)
# VITE_MOCK_ERROR=true

# Panel admin: solo lectura (oculta formularios y acciones de edición)
# VITE_ADMIN_READONLY=true

# Pestaña "Historial" de citas (por defecto activa; pon false para ocultarla)
# VITE_ENABLE_HISTORIAL=false
